<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.HomePage" 
             xmlns:models="clr-namespace:DoAnCSharp.Models"
             Title="{Binding Lang[tab_home]}"
             BackgroundColor="#F4F7F9"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,0,0,30">
            <Border BackgroundColor="#FF6B6B" StrokeThickness="0" Margin="0,0,0,15">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,30,30" /></Border.StrokeShape>
                <VerticalStackLayout Padding="20,50,20,30" Spacing="15">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{Binding Lang[vk_street]}" FontSize="13" TextColor="#FFEAEA" FontAttributes="Bold" TextTransform="Uppercase"/>
                            <Label Text="{Binding Lang[welcome]}" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,5,0,0" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 25" HeightRequest="50" WidthRequest="50" StrokeThickness="0">
                             <Image Source="{Binding UserImage}" Aspect="AspectFill" />
                        </Border>
                    </Grid>
                    
                    <Border StrokeShape="RoundRectangle 16" BackgroundColor="White" StrokeThickness="0" HeightRequest="55">
                        <Grid ColumnDefinitions="Auto, *" Padding="15,0">
                            <Label Text="🔍" VerticalOptions="Center" FontSize="20"/>
                            <Entry x:Name="SearchEntry" 
                                   Grid.Column="1" 
                                   Placeholder="{Binding Lang[search_home]}" 
                                   TextChanged="OnSearchTextChanged"
                                   Focused="OnSearchFocused" 
                                   Unfocused="OnSearchUnfocused" 
                                   Completed="OnSearchCompleted"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="12" Padding="20,5,20,15">
                    <Button x:Name="BtnPhoBien" Text="{Binding Lang[popular_btn]}" Clicked="OnCategoryClicked" BackgroundColor="#FF6B6B" CornerRadius="22"/>
                    <Button x:Name="BtnQuanOc" Text="{Binding Lang[snail_btn]}" Clicked="OnCategoryClicked" BackgroundColor="White" TextColor="#2C3E50" CornerRadius="22"/>
                    <Button x:Name="BtnLauNuong" Text="{Binding Lang[hotpot_btn]}" Clicked="OnCategoryClicked" BackgroundColor="White" TextColor="#2C3E50" CornerRadius="22"/>
                </HorizontalStackLayout>
            </ScrollView>

            <Label Text="{Binding Lang[recommend]}" FontSize="20" FontAttributes="Bold" Margin="20,5" TextColor="#2C3E50"/>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecommendedPois}" Spacing="15" Padding="20,5">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:AudioPOI">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            
                            <Grid ColumnDefinitions="110, *, 40">
                                <Image Source="{Binding ImageAsset}" Aspect="AspectFill" HeightRequest="110" />
                                <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="17" TextColor="#2C3E50"/>
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="⭐ 4.8" FontSize="12" TextColor="#FF6B6B" FontAttributes="Bold" />
                                        <Label Text="{Binding DistanceInfo}" FontSize="12" TextColor="#16A085"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding DisplayDescription}" FontSize="13" TextColor="#7F8C8D" MaxLines="2"/>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" BackgroundColor="#F4F7F9" StrokeThickness="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" VerticalOptions="Center">
                                    <Label Text="▶️" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="{Binding SearchResultTitle}" FontSize="20" FontAttributes="Bold" Margin="20,10" TextColor="#2C3E50"/>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding AllPois}" Spacing="15" Padding="20,5">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:AudioPOI">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            
                            <Grid ColumnDefinitions="110, *, 40">
                                <Image Source="{Binding ImageAsset}" Aspect="AspectFill" HeightRequest="110" />
                                <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="17" TextColor="#2C3E50"/>
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="⭐ 4.8" FontSize="12" TextColor="#FF6B6B" FontAttributes="Bold" />
                                        <Label Text="{Binding DistanceInfo}" FontSize="12" TextColor="#16A085"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding DisplayDescription}" FontSize="13" TextColor="#7F8C8D" MaxLines="2"/>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" BackgroundColor="#F4F7F9" StrokeThickness="0" HeightRequest="36" WidthRequest="36" StrokeShape="RoundRectangle 18" VerticalOptions="Center">
                                    <Label Text="▶️" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>