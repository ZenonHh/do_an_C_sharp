<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.ProfilePage"
             xmlns:viewmodels="clr-namespace:DoAnCSharp.ViewModels"
             xmlns:views="clr-namespace:DoAnCSharp.Views"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#F4F6F8"
             Title="{Binding Lang[profile], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}">

    <ScrollView>
        <Grid>
            <VerticalStackLayout IsVisible="{Binding IsNotLoggedIn}" VerticalOptions="Start" Spacing="20" Padding="20,40,20,20">

                <!-- Dòng chuyển đổi ngôn ngữ (luôn hiện dù chưa đăng nhập) -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" Padding="20">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ChangeLanguageCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="🌐" FontSize="22" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding Lang[language_choice], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}" FontSize="16" VerticalOptions="Center" TextColor="#34495E"/>
                        <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Cài đặt Server URL -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Padding="20" Spacing="10">
                        <Label Text="⚙️ Server URL" FontSize="16" FontAttributes="Bold" TextColor="#34495E"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Entry x:Name="ServerUrlEntryGuest" Grid.Column="0"
                                   Placeholder="http://192.168.x.x:5000"
                                   FontSize="13" TextColor="#2C3E50"
                                   PlaceholderColor="#BDC3C7"
                                   ReturnType="Done"
                                   Keyboard="Url"/>
                            <Button Grid.Column="1" Text="Lưu"
                                    Clicked="OnSaveServerUrlGuestClicked"
                                    BackgroundColor="#3F8CFF" TextColor="White"
                                    CornerRadius="8" FontSize="13"
                                    Padding="12,0" HeightRequest="42"/>
                        </Grid>
                        <Label x:Name="ServerUrlStatusGuest" FontSize="11" TextColor="#95A5A6"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Nút đăng nhập / đăng ký -->
                <Button Text="{Binding Lang[login_register], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}"
                        Command="{Binding GoToLoginCommand}"
                        BackgroundColor="#3F8CFF"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="55"
                        FontAttributes="Bold"
                        FontSize="16"
                        Margin="0,10,0,0">
                    <Button.Shadow>
                        <Shadow Brush="#3F8CFF" Offset="0,5" Radius="10" Opacity="0.3" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsLoggedIn}" Spacing="25" Padding="20,40,20,20">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeShape="RoundRectangle 60" HeightRequest="120" WidthRequest="120" StrokeThickness="3" Stroke="#3F8CFF" HorizontalOptions="Center">
                        <Image Source="{Binding CurrentUser.Avatar}" Aspect="AspectFill" />
                    </Border>
                    <Label Text="{Binding CurrentUser.FullName}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
                    <Label Text="{Binding CurrentUser.Email}" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHistoryTapped" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="🎧" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding Lang[history], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}" FontSize="16" VerticalOptions="Center" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPaymentTapped" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="💳" FontSize="22" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Lang[payment_menu], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}"
                                       FontSize="16" TextColor="#34495E"/>
                                <Label x:Name="QuotaLabel" Text="..." FontSize="12" TextColor="#95A5A6"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeLanguageCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="🌐" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding Lang[language_choice], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}" FontSize="16" VerticalOptions="Center" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEditProfileTapped" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="👤" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding Lang[edit_profile], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}" FontSize="16" VerticalOptions="Center" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Cài đặt Server URL -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <VerticalStackLayout Padding="20" Spacing="10">
                        <Label Text="⚙️ Server URL" FontSize="16" FontAttributes="Bold" TextColor="#34495E"/>
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                            <Entry x:Name="ServerUrlEntry" Grid.Column="0"
                                   Placeholder="http://192.168.x.x:5000"
                                   FontSize="13" TextColor="#2C3E50"
                                   PlaceholderColor="#BDC3C7"
                                   ReturnType="Done"
                                   Keyboard="Url"/>
                            <Button Grid.Column="1" Text="Lưu"
                                    Clicked="OnSaveServerUrlClicked"
                                    BackgroundColor="#3F8CFF" TextColor="White"
                                    CornerRadius="8" FontSize="13"
                                    Padding="12,0" HeightRequest="42"/>
                        </Grid>
                        <Label x:Name="ServerUrlStatus" FontSize="11" TextColor="#95A5A6"/>
                    </VerticalStackLayout>
                </Border>

                <Button Text="{Binding Lang[logout], Source={RelativeSource AncestorType={x:Type views:ProfilePage}}}" 
                        Clicked="OnLogoutClicked"
                        BackgroundColor="#FF4757" 
                        TextColor="White" 
                        CornerRadius="12" 
                        HeightRequest="55" 
                        FontAttributes="Bold" 
                        FontSize="16" 
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>