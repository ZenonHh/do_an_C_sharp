<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.HistoryPage"
             xmlns:models="clr-namespace:DoAnCSharp.Models"
             xmlns:viewmodels="clr-namespace:DoAnCSharp.ViewModels"
             x:DataType="viewmodels:HistoryViewModel"
             Title="Lịch sử đã nghe"
             BackgroundColor="#F4F6F8">

	<CollectionView ItemsSource="{Binding GroupedHistory}" IsGrouped="True" SelectionMode="None" Margin="0,10,0,0">

		<CollectionView.GroupHeaderTemplate>
			<DataTemplate x:DataType="viewmodels:HistoryGroup">
				<Label Text="{Binding DateName}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" Margin="20,15,20,10" />
			</DataTemplate>
		</CollectionView.GroupHeaderTemplate>

		<CollectionView.ItemTemplate>
			<DataTemplate x:DataType="models:PlayHistory">
				<VerticalStackLayout BackgroundColor="White">
					<Grid ColumnDefinitions="Auto, *, Auto" Padding="20,15">

						<Image Grid.Column="0" Source="{Binding ImageAsset}" Aspect="AspectFill" HeightRequest="50" WidthRequest="50">
							<Image.Clip>
								<RoundRectangleGeometry CornerRadius="25" Rect="0,0,50,50"/>
							</Image.Clip>
						</Image>

						<VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0" Spacing="2">
							<Label Text="{Binding PoiName}" FontAttributes="Bold" FontSize="16" TextColor="#34495E" MaxLines="1" LineBreakMode="TailTruncation"/>
							<Label Text="{Binding PlayedAt, StringFormat='{}{0:HH:mm}'}" FontSize="13" TextColor="#7F8C8D"/>
						</VerticalStackLayout>

						<Label Grid.Column="2" Text="🎵" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
					</Grid>

					<BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>
				</VerticalStackLayout>
			</DataTemplate>
		</CollectionView.ItemTemplate>

	</CollectionView>
</ContentPage>