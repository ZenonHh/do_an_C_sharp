<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:DoAnCSharp.Views"
             x:Class="DoAnCSharp.Views.MapPage"
             Title="{Binding Lang[tab_map], Source={RelativeSource AncestorType={x:Type views:MapPage}}}">

    <Grid>
        <WebView x:Name="foodMapView" ZIndex="0" VerticalOptions="Fill" HorizontalOptions="Fill"/>

        <Border VerticalOptions="Start" HorizontalOptions="Fill" Margin="15, 40, 15, 0" BackgroundColor="White" StrokeThickness="0" HeightRequest="50" ZIndex="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="15,0">
                <Label Grid.Column="0" Text="🔍" FontSize="20" VerticalOptions="Center" TextColor="#7F8C8D" />
                
                <Entry x:Name="SearchEntry" 
                       Grid.Column="1" 
                       Placeholder="{Binding Lang[search_hint], Source={RelativeSource AncestorType={x:Type views:MapPage}}}" 
                       TextChanged="OnSearchTextChanged" 
                       TextColor="#2C3E50" 
                       PlaceholderColor="#95A5A6" 
                       BackgroundColor="Transparent" 
                       VerticalOptions="Center" 
                       Margin="10,0" 
                       ClearButtonVisibility="WhileEditing" />
                
                <Border Grid.Column="2" StrokeThickness="0" HeightRequest="30" WidthRequest="30" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Image x:Name="MapUserAvatar" Source="dotnet_bot.png" Aspect="AspectFill" />
                </Border>
            </Grid>
        </Border>

        <Border x:Name="SearchSuggestionsContainer" IsVisible="False" VerticalOptions="Start" HorizontalOptions="Fill" Margin="15, 95, 15, 0" BackgroundColor="White" StrokeThickness="0" ZIndex="3" MaximumHeightRequest="200">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>
            <CollectionView x:Name="SuggestionsList" SelectionMode="Single" SelectionChanged="OnSuggestionSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="15, 12">
                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />
                            <BoxView HeightRequest="1" Color="#F4F6F8" VerticalOptions="End" HorizontalOptions="Fill" Margin="-15,0,-15,-12"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="End" Margin="0, 110, 15, 0" Spacing="12" ZIndex="1">
            <Button Text="📷" Clicked="OnScanQRClicked" BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>

            <Button Text="🎯" FontSize="16" Clicked="CustomMyLocationClicked" BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>

            <Button x:Name="HeatmapToggleButton" Text="🔥" FontSize="16"
                    Clicked="OnHeatmapToggleClicked"
                    BackgroundColor="White" CornerRadius="19"
                    WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <Border x:Name="PoiDetailCard" IsVisible="False" VerticalOptions="End" HorizontalOptions="Fill" Margin="20, 0, 20, 30" Padding="0" BackgroundColor="White" StrokeThickness="0" ZIndex="4">
            <Border.GestureRecognizers>
                <TapGestureRecognizer />
            </Border.GestureRecognizers>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#2C3E50" Offset="0,10" Radius="25" Opacity="0.15" />
            </Border.Shadow>

            <Grid RowDefinitions="180, Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                <Image x:Name="DetailImage" Grid.Row="0" Grid.ColumnSpan="2" Aspect="AspectFill" HeightRequest="180" />
                <BoxView Grid.Row="0" Grid.ColumnSpan="2" Color="Black" Opacity="0.2" VerticalOptions="Start" HeightRequest="60" />

                <Button Grid.Row="0" Grid.Column="1" Text="✕" BackgroundColor="#B3000000" TextColor="White" FontSize="14" FontAttributes="Bold" Clicked="CloseDetailClicked" WidthRequest="34" HeightRequest="34" CornerRadius="17" Margin="15" VerticalOptions="Start" HorizontalOptions="End" Padding="0" />

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="20, 15, 20, 5" Spacing="8">
                    <Label x:Name="DetailName" Text="..." FontAttributes="Bold" FontSize="24" TextColor="#2C3E50" />

                    <HorizontalStackLayout Spacing="10">
                        <Border BackgroundColor="#FFF0F0" StrokeThickness="0" Padding="8,4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Label Text="⭐ 4.8" FontSize="13" TextColor="#FF6B6B" FontAttributes="Bold" />
                        </Border>

                        <Border BackgroundColor="#E8F6F3" StrokeThickness="0" Padding="8,4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Label x:Name="DetailDistance" 
                                   Text="{Binding Lang[calculating], Source={RelativeSource AncestorType={x:Type views:MapPage}}}" 
                                   FontSize="13" TextColor="#16A085" FontAttributes="Bold" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Label x:Name="DetailDescription" Grid.Row="2" Grid.ColumnSpan="2" Text="..." TextColor="#7F8C8D" FontSize="14" Margin="20, 10, 20, 15" LineBreakMode="WordWrap" />

                <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="20, 0, 20, 20">
                    <Button Grid.Column="0"
                            Text="{Binding Lang[direction], Source={RelativeSource AncestorType={x:Type views:MapPage}}}"
                            BackgroundColor="#3498DB" TextColor="White" CornerRadius="18" FontAttributes="Bold" FontSize="15"
                            Clicked="OnGetDirectionsClicked" HeightRequest="50">
                        <Button.Shadow><Shadow Brush="#3498DB" Offset="0,4" Radius="10" Opacity="0.3"/></Button.Shadow>
                    </Button>

                    <Button x:Name="PlayReviewButton"
                            Grid.Column="1"
                            Text="{Binding Lang[listen_review], Source={RelativeSource AncestorType={x:Type views:MapPage}}}"
                            BackgroundColor="#FF6B6B" TextColor="White" CornerRadius="18" FontAttributes="Bold" FontSize="15"
                            Clicked="PlayReviewFromDetailClicked" HeightRequest="50">
                        <Button.Shadow><Shadow Brush="#FF6B6B" Offset="0,4" Radius="10" Opacity="0.3"/></Button.Shadow>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Debug location simulator — shown only in DEBUG builds via code-behind -->
        <Border x:Name="DebugPanel" IsVisible="False"
                VerticalOptions="End" HorizontalOptions="Start"
                Margin="10,0,0,140" Padding="10,8"
                BackgroundColor="#DD1a1a2e" StrokeThickness="0" ZIndex="10">
            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="5">
                <Label Text="🧪 Giả lập vị trí" TextColor="#FFD700" FontSize="11" FontAttributes="Bold"/>
                <Entry x:Name="DebugLatEntry" Placeholder="Latitude" Text="10.7584"
                       TextColor="White" PlaceholderColor="#888" BackgroundColor="Transparent" FontSize="12" WidthRequest="145"/>
                <Entry x:Name="DebugLngEntry" Placeholder="Longitude" Text="106.70535"
                       TextColor="White" PlaceholderColor="#888" BackgroundColor="Transparent" FontSize="12" WidthRequest="145"/>
                <Label x:Name="DebugResultLabel" Text="" TextColor="#7FFF7F" FontSize="10" LineBreakMode="WordWrap"/>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                    <Button Grid.Column="0" Text="▶ Thử" Clicked="OnSimulateLocationClicked"
                            BackgroundColor="#FF6B35" TextColor="White" FontSize="11"
                            CornerRadius="7" HeightRequest="30" Padding="0"/>
                    <Button Grid.Column="1" Text="✕ Xóa" Clicked="OnClearSimulatedLocationClicked"
                            BackgroundColor="#555" TextColor="White" FontSize="11"
                            CornerRadius="7" HeightRequest="30" Padding="0"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border x:Name="AudioPlayerUI" IsVisible="False" VerticalOptions="End" HorizontalOptions="Fill" Margin="20, 0, 20, 20" Padding="15, 12" BackgroundColor="#EB1A1A1A" StrokeThickness="0" ZIndex="5">
            <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                <Grid Grid.Column="0" WidthRequest="32" HeightRequest="32">
                    <Label Text="🔊" FontSize="28" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <ActivityIndicator x:Name="TranslationLoader" IsRunning="False" IsVisible="False" Color="White" Scale="0.8"/>
                </Grid>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                    <Label x:Name="AudioStatusLabel" 
                           Text="{Binding Lang[narrating], Source={RelativeSource AncestorType={x:Type views:MapPage}}}" 
                           TextColor="Gray" FontSize="11"/>
                    <Label x:Name="AudioText" Text="..." TextColor="White" FontAttributes="Bold" FontSize="17" MaxLines="1" LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
                <Button x:Name="PlayStopButton" Grid.Column="2" Text="⏹" Clicked="ToggleAudioClicked" BackgroundColor="#FF4444" TextColor="White" CornerRadius="22" WidthRequest="44" HeightRequest="44" Padding="0" VerticalOptions="Center"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>