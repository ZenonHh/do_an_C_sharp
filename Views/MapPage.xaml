<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:map="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="DoAnCSharp.Views.MapPage"
             Title="Bản đồ Vĩnh Khánh">

    <Grid>
        <map:MapView x:Name="foodMapView" 
                     VerticalOptions="Fill" 
                     HorizontalOptions="Fill" 
                     IsZoomButtonVisible="False"
                     IsMyLocationButtonVisible="False"
                     IsNorthingButtonVisible="False"/>

        <VerticalStackLayout VerticalOptions="Start" 
                             HorizontalOptions="End" 
                             Margin="0, 50, 20, 0" 
                             Spacing="15">

            <Button Text="🎯"
                    FontSize="24"
                    Clicked="CustomMyLocationClicked"
                    BackgroundColor="White"
                    CornerRadius="25"
                    WidthRequest="50"
                    HeightRequest="50"
                    Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.3}" />

            <Button Text="🌐"
                    FontSize="24"
                    Clicked="OnLanguageClicked"
                    BackgroundColor="White"
                    CornerRadius="25"
                    WidthRequest="50"
                    HeightRequest="50"
                    Shadow="{Shadow Brush=Black, Offset='0,3', Opacity=0.3}" />
        </VerticalStackLayout>

        <Border x:Name="PoiDetailCard"
                IsVisible="False"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="20, 0, 20, 30"
                Padding="0" 
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 25">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.15" />
            </Border.Shadow>

            <Grid RowDefinitions="150, Auto, Auto, Auto" ColumnDefinitions="*, Auto">

                <Image x:Name="DetailImage" Grid.Row="0" Grid.ColumnSpan="2" Aspect="AspectFill" HeightRequest="150" />

                <Button Grid.Row="0" Grid.Column="1" Text="✕" BackgroundColor="#80000000" TextColor="White" FontSize="16" Clicked="CloseDetailClicked" WidthRequest="36" HeightRequest="36" CornerRadius="18" Margin="10" VerticalOptions="Start" HorizontalOptions="End" Padding="0" />

                <Label x:Name="DetailName" Grid.Row="1" Grid.Column="0" Text="Tên Quán" FontAttributes="Bold" FontSize="22" TextColor="#2C3E50" Margin="20, 15, 20, 5" />

                <Label x:Name="DetailDescription" Grid.Row="2" Grid.ColumnSpan="2" Text="Mô tả chi tiết..." TextColor="#7F8C8D" FontSize="14" Margin="20, 0, 20, 15" LineBreakMode="WordWrap" />

                <Button x:Name="PlayReviewButton" Grid.Row="3" Grid.ColumnSpan="2" Text="🔊 Nghe Review" BackgroundColor="#FF4757" TextColor="White" CornerRadius="15" FontAttributes="Bold" Clicked="PlayReviewFromDetailClicked" HeightRequest="45" Margin="20, 0, 20, 20" />
            </Grid>
        </Border>

        <Border x:Name="AudioPlayerUI" 
                IsVisible="False"
                VerticalOptions="End" 
                HorizontalOptions="Fill"
                Margin="20, 0, 20, 20" 
                Padding="15, 12"
                BackgroundColor="#EB1A1A1A" 
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20">

            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                <Label Grid.Column="0" Text="🔊" FontSize="32" VerticalOptions="Center"/>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                    <Label x:Name="AudioStatusLabel" 
                           Text="Đang phát review:" 
                           TextColor="{StaticResource Gray300}" 
                           FontSize="12"/>
                    <Label x:Name="AudioText" 
                           Text="Ốc Oanh" 
                           TextColor="White" 
                           FontAttributes="Bold"
                           FontSize="18"
                           MaxLines="1"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>

                <Button x:Name="PlayStopButton"
                        Grid.Column="2"
                        Text="⏹" 
                        Clicked="ToggleAudioClicked" 
                        BackgroundColor="#FF4444"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        WidthRequest="50"
                        HeightRequest="50"
                        Padding="0"
                        VerticalOptions="Center"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>