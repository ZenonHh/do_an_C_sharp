<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DoAnCSharp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DoAnCSharp"
    xmlns:views="clr-namespace:DoAnCSharp.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Shell.TabBarBackgroundColor="White"
            Shell.TabBarForegroundColor="#FF4757"
            Shell.TabBarTitleColor="#FF4757"
            Shell.TabBarUnselectedColor="#95A5A6">

        <Tab x:Name="TabMap" Route="MapTab" Title="Bản Đồ" Icon="map_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" />
        </Tab>

        <Tab x:Name="TabHome" Route="HomeTab" Title="Trang Chủ" Icon="home_icon.png"> 
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" />
        </Tab>

        <Tab x:Name="TabProfile" Route="ProfileTab" Title="Tôi" Icon="profile_icon.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
        
    </TabBar>
</Shell>