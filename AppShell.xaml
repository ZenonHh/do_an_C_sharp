<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DoAnCSharp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DoAnCSharp"
    xmlns:views="clr-namespace:DoAnCSharp.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar Shell.TabBarBackgroundColor="{StaticResource White}"
            Shell.TabBarForegroundColor="{StaticResource Primary}"
            Shell.TabBarTitleColor="{StaticResource Primary}"
            Shell.TabBarUnselectedColor="{StaticResource Gray500}">
        
        <Tab Title="Trang chủ">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        
        <Tab Title="Bản đồ">
            <ShellContent ContentTemplate="{DataTemplate views:MapPage}" />
        </Tab>
        
        <Tab Title="Cá nhân">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
        
    </TabBar>
</Shell>